# Root directory containing date subdirectories with .log files.
PARSER_SOURCE_PATH=parser_test

# Path to write the output CSV file.
PARSER_OUTPUT_PATH=output.csv

# Path to the appCodes.ini file used to resolve app display names to kebab-case codes.
# Can be overridden at runtime with the --ini option.
PARSER_INI_PATH=parser_test/appCodes.ini
